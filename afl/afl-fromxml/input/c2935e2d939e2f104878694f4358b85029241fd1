							<Variables>
								<Declare Name="LoL"/>
								<Declare Name="HiL"/>
								<Declare Name="MaxAmbientL"/>
								<Declare Name="AmbientL"/>
								<Declare Name="LoJND"/>
								<Declare Name="HiJND"/>
								<Declare Name="RangeJND"/>
								<Declare Name="RangeDL"/>
							</Variables>
							<MainFunction>
{
;Initialize constants based on measurement of display luminance (in dark environment) and ambient luminance of environment
10 tput{LoL} ;Low luminance level based on measurement of device in Dark environment (should match FirstEntry attribute of curve{LtoDL})
1000 tput{HiL} ;High luminance level based on measurement of device in Dark environment (should match LastEntry attribute of curve{LtoDL})

;Determine max ambient luminance
3993.32958588733 tget{HiL} sub tput{MaxAmbientL} ;(3933.32958588733 should be same as last value of curve{JNDtoL})

;Get Ambience level from cmm environment variable and validate it
env(ambL) if { 0 max } else { pop 10 } ; get ambient luminance level from 'ambL' CMM environment variable (default is 10 cd/m^2)
tget{MaxAmbientL} min tput{AmbientL}

%Use measured Luminance form display and ambient luminance to determine lo and hi JND levels
tget{LoL} tget{AmbientL} add log curv{LogLtoJND} tput{LoJND}; LtoJND(log(LoL+AmbientL\))
tget{HiL} tget{AmbientL} add log curv{LogLtoJND} tput{HiJND}; LtoJND(log(HiL+AmbientL))

;Determine JND range of display in ambient environment
tget{HiJND} tget{LoJND} sub tput{RangeJND}

;Determine range of Drive Levels corresponding to JND range
tget{HiJND} curv{JNDtoL} tget{AmbientL} sub curv{LtoDL} tput{RangeDL}

;Now apply GSDF function

;scale JND range by inputJND percent, add LoJND
in{inputJND} tget{RangeJND} mul tget{LoJND} add ;determine JND point for input

;convert JND to luminance and subtract out ambient luminance
curv{JNDtoL} tget{AmbientL} sub; determine desired luminance on display

;convert diaplay luminace to drive level of display
curv{LtoDL} ;apply desired display luminance to drive value conversion

;Finally divide by range of drive levels to get out percent Drive Level
tget{RangeDL} div ; correct for floating point rounding of maximum point
out[0]
}

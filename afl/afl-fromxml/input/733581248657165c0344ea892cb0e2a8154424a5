					<!--curve{LtoDL} converts measured Luminance (L) to display Drive Level (DL) -->
					<CurveSetElement Name="LtoDL" InputChannels="1" OutputChannels="1"> 
						<!-- This example assumes linear luminance response of device -->
						<!-- To work with actual device measure luminance for each drive level.-->
						<!-- Then invert to determine fractional drive levels for each linear increment of luminance, and put in SingleSampledCurveSegment-->

digraph "IccTiffDump" {
	// Clean graph styling — auto-sized for browser viewing
	graph [
		rankdir=LR,
		nodesep=0.3,
		ranksep=0.8,
		fontname="Helvetica",
		fontsize=10,
		bgcolor="white",
		pad=0.3
	];
	node [
		shape=box,
		style="rounded,filled",
		fillcolor="#f0f4ff",
		fontname="Courier",
		fontsize=9,
		margin="0.08,0.04"
	];
	edge [
		color="#4a6fa5",
		arrowsize=0.6
	];
  rankdir=LR;
  node [shape=box, style="rounded,filled", fillcolor="#2d2d2d", fontcolor="white", fontname="Consolas"];
  edge [color="#666666"];

  "DumpProfileInfo";
  "GetProfile";
  "GetSpectralColorSigName";
  "GetText";
  "ReadTags";
  "Usage";
  "begin";
  "c_str";
  "fclose";
  "fopen";
  "fwrite";
  "icF16toF";
  "if";

  "if" -> "c_str";
  "if" -> "GetSpectralColorSigName";
  "if" -> "icF16toF";
  "if" -> "GetText";
  "if" -> "begin";
  "if" -> "DumpProfileInfo";
  "if" -> "GetProfile";
  "if" -> "Usage";
  "if" -> "fopen";
  "if" -> "fwrite";
  "if" -> "fclose";
  "if" -> "ReadTags";
}
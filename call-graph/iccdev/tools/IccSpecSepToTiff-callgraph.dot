digraph "IccSpecSepToTiff" {
  rankdir=LR;
  node [shape=box, style="rounded,filled", fillcolor="#2d2d2d", fontcolor="white", fontname="Consolas"];
  edge [color="#666666"];

  "Close";
  "GetLength";
  "Read8";
  "SetIccProfile";
  "Usage";
  "get";
  "if";
  "reset";
  "strrchr";

  "if" -> "strrchr";
  "if" -> "Usage";
  "if" -> "GetLength";
  "if" -> "reset";
  "if" -> "Read8";
  "if" -> "get";
  "if" -> "SetIccProfile";
  "if" -> "Close";
}
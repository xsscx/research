+int CIccCalculatorFunc::CheckUnderflowOverflow(SIccCalcOp *op, icUInt32Number nOps, int nArgs, bool bCheckUnderflow, std::string &sReport, int nDepth) const
 {
+  // CFL-010: prevent stack overflow from deeply nested if/else/case (CWE-674)
+  if (nDepth > 64) {
+    sReport += "Calculator recursion depth exceeds limit\n";
+    return -1;
+  }
+
   icUInt32Number i, p;
   int nIfArgs, nElseArgs, nSelArgs, nCaseArgs;
 

@@ -3748,6 +3748,15 @@
 void CIccTagXYZ::Describe(std::string &sDescription, int /* nVerboseness */)
 {
+  // CFL-080: Cap Describe() output to 1MB. XYZ tags with crafted m_nSize
+  // can produce 320GB+ of text (16M entries × 20 bytes each).
+  // Same pattern affects Chromaticity and ColorantTable below.
+  // The cap truncates output with notice rather than producing
+  // unbounded allocation. CWE-400.
+  static const size_t kMaxDescribeSize = 1048576; // 1 MB
+  if (sDescription.size() > kMaxDescribeSize)
+    return;
+
   const size_t bufSize = 80;
   icChar buf[bufSize];
 
@@ -3755,6 +3764,8 @@
   for (int i=0; i<(int)m_nSize; i++) {
     snprintf(buf, bufSize, "value[%d]:  X=%.4lf, Y=%.4lf, Z=%.4lf\n", i,
        icFtoD(m_XYZ[i].X), icFtoD(m_XYZ[i].Y), icFtoD(m_XYZ[i].Z));
+    if (sDescription.size() > kMaxDescribeSize)
+      break;
     sDescription += buf;
   }
 }

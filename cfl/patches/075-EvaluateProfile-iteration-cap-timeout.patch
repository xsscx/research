+  // Cap total iterations to prevent exponential blowup (CWE-400).
+  // nGran^ndim iterations with 2 Apply() calls each; e.g. 33^6 = 1.29B is too many.
+  // Reduce nGran for high-dimensional profiles to keep total under 10M iterations.
+  {
+    static const icUInt64Number kMaxIterations = 100000ULL;
+    icUInt64Number totalIter = 1;
+    for (int d = 0; d < ndim; d++) {
+      totalIter *= nGran;
+      if (totalIter > kMaxIterations) {
+        // Reduce granularity: find largest nGran where nGran^ndim <= kMaxIterations
+        icUInt8Number g = 2;
+        while (g < nGran) {
+          icUInt64Number t = 1;
+          bool overflow = false;
+          for (int dd = 0; dd < ndim; dd++) {
+            t *= (g + 1);
+            if (t > kMaxIterations) { overflow = true; break; }
+          }
+          if (overflow) break;
+          g++;
+        }
+        nGran = g;
+        break;
+      }
+    }
+  }

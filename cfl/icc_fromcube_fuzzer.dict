# ═══════════════════════════════════════════════════════════════════
# SECTION 19: ICC profile construction tokens (downstream from cube)
# SaveIccProfile builds an ICC profile — these exercise tag/header paths
# ═══════════════════════════════════════════════════════════════════
# ICC magic bytes
icc_magic="\x61\x63\x73\x70"
# ICC class signatures
icc_class_abst="abst"
icc_class_link="link"
icc_class_mntr="mntr"
icc_class_prtr="prtr"
icc_class_scnr="scnr"
icc_class_spac="spac"
# ICC color space sigs
icc_cs_rgb="RGB "
icc_cs_cmyk="CMYK"
icc_cs_lab="Lab "
icc_cs_xyz="XYZ "
icc_cs_gray="GRAY"
# ICC tag sigs (used by SaveIccProfile)
icc_tag_desc="desc"
icc_tag_cprt="cprt"
icc_tag_wtpt="wtpt"
icc_tag_A2B0="A2B0"
icc_tag_B2A0="B2A0"
icc_tag_chad="chad"
icc_tag_clut="clut"
icc_tag_curv="curv"
icc_tag_mpet="mpet"
icc_tag_mAB="mAB "
icc_tag_mBA="mBA "
# ICC version BCD
icc_v2="\x02\x40\x00\x00"
icc_v4="\x04\x40\x00\x00"
icc_v5="\x05\x10\x00\x00"
# ICC PCS illuminant D50 (s15Fixed16)
icc_d50_x="\x00\x00\xf6\xd6"
icc_d50_y="\x00\x01\x00\x00"
icc_d50_z="\x00\x00\xd3\x2d"
# Profile creation timestamp fields
icc_date="\x07\xe8\x00\x01\x00\x01\x00\x00\x00\x00\x00\x00"

# ═══════════════════════════════════════════════════════════════════
# SECTION 20: atof() edge cases (parser attack surface)
# ═══════════════════════════════════════════════════════════════════
atof_empty=""
atof_space=" "
atof_tab="\x09"
atof_hex="0x1p+0"
atof_hex2="0x1.fp+10"
atof_dot_only="."
atof_minus_only="-"
atof_plus_only="+"
atof_exp_only="e10"
atof_leading_zero="007"
atof_trailing_dot="1."
atof_leading_dot=".1"
atof_many_digits="0.1234567890123456789"
atof_subnormal="5e-324"
atof_denorm="2.2250738585072011e-308"
atof_max="1.7976931348623157e+308"
atof_neg_max="-1.7976931348623157e+308"
atof_overflow="1e309"
atof_neg_overflow="-1e309"

# ═══════════════════════════════════════════════════════════════════
# SECTION 21: getNextLine() parser attack surface
# ═══════════════════════════════════════════════════════════════════
# Null byte injection
nl_null="\x00"
# CR-LF line endings
nl_crlf="\x0d\x0a"
# Bare CR
nl_cr="\x0d"
# Mixed line endings in data
nl_mixed="0.0 0.0 0.0\x0d\x0a1.0 1.0 1.0\x0a"
# UTF-8 BOM
nl_bom="\xef\xbb\xbf"
# Very long line (255+ chars)
nl_long="TITLE \"AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA\""

# ═══════════════════════════════════════════════════════════════════
# SECTION 22: Error path triggers
# ═══════════════════════════════════════════════════════════════════
# Missing LUT_3D_SIZE (no size → parse fails)
err_nosize="TITLE \"Test\"\x0a0.0 0.0 0.0\x0a"
# Size=0
err_zero="LUT_3D_SIZE 0\x0a"
# Negative size
err_neg="LUT_3D_SIZE -1\x0a"
# Size > 64 (fuzzer cap)
err_big="LUT_3D_SIZE 100\x0a"
# Extreme size
err_huge="LUT_3D_SIZE 999999999999999\x0a"
# Empty file
err_empty=""
# Only comments
err_comments="# comment 1\x0a# comment 2\x0a"
# Only newlines
err_newlines="\x0a\x0a\x0a"
# Binary garbage
err_garbage="\xff\xfe\xfd\xfc\xfb\xfa"

# ═══════════════════════════════════════════════════════════════════
# SECTION 23: Keyword case/prefix variations (substr() testing)
# ═══════════════════════════════════════════════════════════════════
# Case variations (not matched by substr)
kv_lower="title "
kv_mixed="Title "
kv_lut3d_lower="lut_3d_size "
kv_domain_lower="domain_min "
# Partial keywords
kv_partial1="LUT_"
kv_partial2="DOMAIN"
kv_partial3="LUT_3D"
kv_partial4="LUT_3D_"
kv_partial5="LUT_3D_S"
kv_partial6="LUT_3D_SI"
kv_partial7="LUT_3D_SIZ"
kv_partial8="LUT_3D_SIZE"
# No trailing space (misses substr match)
kv_nospace1="LUT_3D_SIZE"
kv_nospace2="DOMAIN_MIN"
kv_nospace3="DOMAIN_MAX"
# Double space after keyword
kv_dblspace="LUT_3D_SIZE  2"
# Tab after keyword
kv_tab="LUT_3D_SIZE\x092"

# ═══════════════════════════════════════════════════════════════════
# SECTION 24: Multi-keyword header sequences
# ═══════════════════════════════════════════════════════════════════
# Domain before size (reorder)
seq_dbs="DOMAIN_MIN 0.0 0.0 0.0\x0aDOMAIN_MAX 1.0 1.0 1.0\x0aLUT_3D_SIZE 2\x0a"
# Size then domain (normal order)
seq_snd="LUT_3D_SIZE 2\x0aDOMAIN_MIN -1.0 -1.0 -1.0\x0aDOMAIN_MAX 2.0 2.0 2.0\x0a"
# All flags together
seq_all="TITLE \"All Flags\"\x0aLUT_IN_VIDEO_RANGE\x0aLUT_OUT_VIDEO_RANGE\x0aLUT_3D_INPUT_RANGE 0.0 1.0\x0aLUT_3D_SIZE 2\x0a"
# INPUT_RANGE + DOMAIN (both — DOMAIN wins per parse order)
seq_both="LUT_3D_INPUT_RANGE 0.0 1.0\x0aDOMAIN_MIN -0.5 -0.5 -0.5\x0aDOMAIN_MAX 1.5 1.5 1.5\x0aLUT_3D_SIZE 2\x0a"
# Duplicate keywords (second overwrites first)
seq_dup="LUT_3D_SIZE 2\x0aLUT_3D_SIZE 4\x0a"

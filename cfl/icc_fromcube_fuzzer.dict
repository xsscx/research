# icc_fromcube_fuzzer dictionary — focused .cube LUT format tokens
# Targets CubeFile parser (iccFromCube.cpp) + downstream ICC profile construction
#
# Coverage targets:
#   - Header keyword dispatch (8 keywords via substr())
#   - getTitle() quoted vs unquoted paths
#   - getNext() whitespace-delimited value parsing
#   - parse3DTable() triplet parsing, comment/empty-line skipping
#   - LUT_3D_SIZE atoll() + overflow/negative validation
#   - Custom input range → 5 curve sharing branches
#   - SaveIccProfile → CIccProfile::Write → MD5 → tag serialization

# ═══════════════════════════════════════════════════════════════════
# Header keywords (exact substr() match including trailing space)
# ═══════════════════════════════════════════════════════════════════
kw_title="TITLE "
kw_lut3d="LUT_3D_SIZE "
kw_lut1d="LUT_1D_SiZE "
kw_dmin="DOMAIN_MIN "
kw_dmax="DOMAIN_MAX "
kw_inrange="LUT_3D_INPUT_RANGE "
kw_vidin="LUT_IN_VIDEO_RANGE"
kw_vidout="LUT_OUT_VIDEO_RANGE"

# ═══════════════════════════════════════════════════════════════════
# LUT sizes (valid range: 2-64 per fuzzer cap, upstream allows INT_MAX)
# ═══════════════════════════════════════════════════════════════════
sz_2="2"
sz_3="3"
sz_4="4"
sz_5="5"
sz_8="8"
sz_9="9"
sz_16="16"
sz_17="17"
sz_32="32"
sz_33="33"
sz_64="64"
"65"
# Boundary: size=1 rejected by parse3DTable (< 2)
"1"
# Boundary: size=0 rejected by atoll check (<= 0)
"0"
# Large sizes (uint64_t overflow in s*s*s: 1291^3 > UINT_MAX)
"1290"
"1291"
"1292"
"2000"
# Negative size rejected by atoll check (<= 0)
"-1"
"-2"
# INT_MAX overflow via atoll
"2147483647"
"2147483648"
"9999999999999"

# ═══════════════════════════════════════════════════════════════════
# SECTION 3: Float values — exercise atof() in DOMAIN and LUT data
# ═══════════════════════════════════════════════════════════════════
# Standard range
"0.0"
"1.0"
"0.5"
"0.25"
"0.75"
# Non-standard ranges (triggers isCustomInputRange)
"-1.0"
"-0.5"
"2.0"
"1.5"
"3.0"
"100.0"
"-100.0"
# Edge-case floats
"0.0000001"
"0.9999999"
"1e10"
"1e-10"
"-1e38"
"1e38"
"inf"
"-inf"
"nan"
"NaN"
# Additional float edge cases
"1e308"
"-1e308"
"1e-308"
"2.2250738585072014e-308"
"1.7976931348623157e+308"
"-0.0"
"+0.0"
"+1.0"
"+0.5"
"0."
"1."
".0"
".5"
"00.00"
"01.00"

# ═══════════════════════════════════════════════════════════════════
# SECTION 4: Float triplets — exercise parse3DTable() row parsing
# ═══════════════════════════════════════════════════════════════════
"0.0 0.0 0.0"
"1.0 1.0 1.0"
"0.5 0.5 0.5"
"0.0 0.5 1.0"
"1.0 0.0 0.5"
"0.25 0.75 0.5"
"-1.0 2.0 0.0"
# Interpolation boundary values (Skia shader: slice edges at n/(size-1))
"0.0625 0.0625 0.0625"
"0.9375 0.9375 0.9375"
"0.0 0.0 0.5"
"0.5 0.0 1.0"
# Incomplete triplets — trigger parse error paths L229/L235
"0.5"
"0.5 0.5"
"0.0 "
# Values with dot-prefix (no leading zero)
".0 .0 .0"
".5 .5 .5"
".999 .999 .999"
# All-negative data rows
"-0.1 -0.2 -0.3"
"-1.0 -1.0 -1.0"
# Out-of-range values (wide gamut / BT.2020)
"1.05 0.0 0.0"
"-0.01 0.0 0.0"
"0.0 1.04 -0.01"
# Scientific notation in data
"1e-7 0.0 0.0"
"0.0 9.999999e-1 0.0"
# Plus-sign prefix
"+1.0 +0.5 +0.0"

# ═══════════════════════════════════════════════════════════════════
# SECTION 5: Per-channel DOMAIN values — exercise curve sharing logic
# ═══════════════════════════════════════════════════════════════════
# Uniform range (all channels same → curves shared)
"DOMAIN_MIN 0.0"
"DOMAIN_MAX 1.0"
# Per-channel with 1 value (fallback: all channels = same)
"DOMAIN_MIN -1.0"
"DOMAIN_MAX 2.0"
# Per-channel with 2 values (ch2 = ch1 fallback)
"DOMAIN_MIN 0.0 0.5"
"DOMAIN_MAX 1.0 2.0"
# Per-channel with 3 values (all independent → 3 separate curves)
"DOMAIN_MIN 0.0 0.5 1.0"
"DOMAIN_MAX 1.0 2.0 3.0"
# Channels match ch0 (pCurve1=pCurve0, pCurve2=pCurve0)
"DOMAIN_MIN 0.5 0.5 0.5"
"DOMAIN_MAX 2.0 2.0 2.0"
# Ch1 differs, ch2 matches ch1 (pCurve2=pCurve1)
"DOMAIN_MIN 0.0 0.5 0.5"
"DOMAIN_MAX 1.0 2.0 2.0"
# Ch1 matches ch0, ch2 differs (pCurve1=pCurve0, new pCurve2)
"DOMAIN_MIN 0.0 0.0 0.5"
"DOMAIN_MAX 1.0 1.0 2.0"
# All three different (new pCurve1, new pCurve2)
"DOMAIN_MIN 0.0 0.3 0.6"
"DOMAIN_MAX 1.0 1.5 2.0"

# LUT_3D_INPUT_RANGE (2-value: min max)
"LUT_3D_INPUT_RANGE 0.0 1.0"
"LUT_3D_INPUT_RANGE -1.0 2.0"
"LUT_3D_INPUT_RANGE 0.0"

# ═══════════════════════════════════════════════════════════════════
# SECTION 6: Comment and whitespace tokens
# ═══════════════════════════════════════════════════════════════════
"# "
"#"
"# Comment text"
"#comment"
"# "
"#\x09"

# ═══════════════════════════════════════════════════════════════════
# SECTION 7: Title variations — exercise getTitle() quoted/unquoted
# ═══════════════════════════════════════════════════════════════════
"TITLE \"Test LUT\""
"TITLE \"Quoted Title\""
"TITLE Unquoted Title"
"TITLE \"\""
# Long unquoted title (multi-word)
"TITLE Cinema Grade BT2020 DCI P3"
# Title with special chars
"TITLE \"LUT \xe2\x80\x94 v2.0 (final)\""
# Empty title after keyword
"TITLE "
# Multiple TITLE lines (concatenated with \n)
"TITLE \"First\"\x0aTITLE \"Second\""

# ═══════════════════════════════════════════════════════════════════
# SECTION 8: getNext() parser edge cases (whitespace delimited)
# ═══════════════════════════════════════════════════════════════════
# Multiple spaces between values
"0.0  0.0  0.0"
# Leading spaces
" 0.0 0.0 0.0"
# Trailing spaces
"0.0 0.0 0.0 "
# Tab characters (not handled as whitespace by getNext — only spaces)
"\x090.0\x090.0\x090.0"
"0.0\x090.5\x091.0"
# Single value (getNext returns empty → parse error path)
# Two values only (second getNext fails → parse error)
"0.5 0.5"
# Many spaces
"0.0     0.0     0.0"
# Newline variations
"\x0d\x0a"
"\x0a"

# ═══════════════════════════════════════════════════════════════════
# SECTION 9: Line boundary (MAX_LINE_LEN = 255)
# ═══════════════════════════════════════════════════════════════════
# Long line — exercises the n<MAX_LINE_LEN loop limit
"TITLE \"AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA\""

# ═══════════════════════════════════════════════════════════════════
# SECTION 10: Data line detection (first char triggers fseek break)
# ═══════════════════════════════════════════════════════════════════
# Lines starting with digit/dot/minus trigger break out of header
"."
"-"
".5 .5 .5"
"-0.5 0.0 1.0"
# Digits 0-9 all trigger header break
"0 0 0"
"1 1 1"
"9 9 9"

# ═══════════════════════════════════════════════════════════════════
# SECTION 11: Complete mini-CUBE files — exercise full pipeline
# ═══════════════════════════════════════════════════════════════════
# Minimal valid 2x2x2 (no title, no domain, no flags)
"LUT_3D_SIZE 2\x0a0.0 0.0 0.0\x0a1.0 0.0 0.0\x0a0.0 1.0 0.0\x0a1.0 1.0 0.0\x0a0.0 0.0 1.0\x0a1.0 0.0 1.0\x0a0.0 1.0 1.0\x0a1.0 1.0 1.0\x0a"
# With custom input range (triggers curve insertion)
"LUT_3D_INPUT_RANGE 0.0625 0.9375\x0aLUT_3D_SIZE 2\x0a0.0 0.0 0.0\x0a1.0 0.0 0.0\x0a0.0 1.0 0.0\x0a1.0 1.0 0.0\x0a0.0 0.0 1.0\x0a1.0 0.0 1.0\x0a0.0 1.0 1.0\x0a1.0 1.0 1.0\x0a"
# With video range flags
"LUT_IN_VIDEO_RANGE\x0aLUT_OUT_VIDEO_RANGE\x0aLUT_3D_SIZE 2\x0a0.0 0.0 0.0\x0a1.0 0.0 0.0\x0a0.0 1.0 0.0\x0a1.0 1.0 0.0\x0a0.0 0.0 1.0\x0a1.0 0.0 1.0\x0a0.0 1.0 1.0\x0a1.0 1.0 1.0\x0a"
# 1D rejection (correct case: LUT_1D_SiZE with lowercase i)
"LUT_1D_SiZE 8\x0a0.0 0.0 0.0\x0a"
# Truncated data (triggers parse3DTable L456 failure path)
"LUT_3D_SIZE 3\x0a0.0 0.0 0.0\x0a0.5 0.0 0.0\x0a"
# With wide-gamut domain (BT.2020)
"DOMAIN_MIN -0.05 -0.05 -0.05\x0aDOMAIN_MAX 1.09 1.09 1.09\x0aLUT_3D_SIZE 2\x0a0.0 0.0 0.0\x0a1.0 0.0 0.0\x0a0.0 1.0 0.0\x0a1.0 1.0 0.0\x0a0.0 0.0 1.0\x0a1.0 0.0 1.0\x0a0.0 1.0 1.0\x0a1.0 1.0 1.0\x0a"

# ═══════════════════════════════════════════════════════════════════
# SECTION 12: Production LUT sizes (cinema/broadcast workflow)
# ═══════════════════════════════════════════════════════════════════
# Standard DaVinci Resolve sizes
"LUT_3D_SIZE 17"
"LUT_3D_SIZE 33"
# Skia 8x8 grid = 64 slices
"LUT_3D_SIZE 64"
# ACES workflow
"LUT_3D_SIZE 65"
# Broadcast video levels
"LUT_3D_INPUT_RANGE 0.0625 0.9375"
"LUT_3D_INPUT_RANGE 0.0627 0.9216"
# HDR/PQ range
"LUT_3D_INPUT_RANGE 0.0 10000.0"
"DOMAIN_MIN 0.0 0.0 0.0"
"DOMAIN_MAX 10000.0 10000.0 10000.0"


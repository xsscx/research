diff --git a/IccProfLib/IccApplyBPC.cpp b/IccProfLib/IccApplyBPC.cpp
index 04b6cd5..29cd833 100644
--- a/IccProfLib/IccApplyBPC.cpp
+++ b/IccProfLib/IccApplyBPC.cpp
@@ -560,10 +560,17 @@ bool CIccApplyBPC::pixelXfm(icFloatNumber *DstPixel, icFloatNumber *SrcPixel, ic
 		return false;
 	}
 
-	// Apply the pixel
-	if (cmm.Apply(DstPixel, SrcPixel)!=icCmmStatOk) {
+	// Guard: callers pass XYZb[3] as DstPixel but a malformed profile's LUT
+	// may have m_nOutput > 3, causing a stack-buffer-overflow (CWE-121).
+	// The declared dest space cannot be trusted for malformed profiles, so
+	// always apply into a local buffer and copy back only 3 XYZ values.
+	icFloatNumber tmpPixel[16] = {};
+	if (cmm.Apply(tmpPixel, SrcPixel) != icCmmStatOk) {
 		return false;
 	}
+	DstPixel[0] = tmpPixel[0];
+	DstPixel[1] = tmpPixel[1];
+	DstPixel[2] = tmpPixel[2];
 
 	return true;
 }

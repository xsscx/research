@@ -3088,6 +3088,14 @@
 void CIccTagNamedColor2::Describe(std::string &sDescription, int /* nVerboseness */)
 {
   const size_t bufSize = 128;
+
+  // CFL-078: Cap Describe() iteration to prevent multi-second hangs on
+  // profiles with millions of named color entries. m_nSize can reach ~3.5M

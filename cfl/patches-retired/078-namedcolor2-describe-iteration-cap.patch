+  // Cap to 10K entries with truncation notice. CWE-400.
+  static const icUInt32Number kMaxDescribeEntries = 10000;
+  icUInt32Number nDescribeLimit = (m_nSize > kMaxDescribeEntries) ? kMaxDescribeEntries : m_nSize;
+
   const size_t nameSize = 40;
   icChar buf[bufSize], szColorVal[nameSize], szColor[nameSize];
 
@@ -3108,7 +3116,7 @@
   snprintf(buf, bufSize, "Sufix= \"%s\"\n", m_szSufix);
   sDescription += buf;
 
-  for (i=0; i<m_nSize; i++) {
+  for (i=0; i<nDescribeLimit; i++) {
     snprintf(buf, bufSize, "Color[%u]: %s :", i, pNamedColor->rootName);
     sDescription += buf;
     
@@ -3140,6 +3148,11 @@
 
     pNamedColor = (SIccNamedColorEntry*)((icChar*)pNamedColor + m_nColorEntrySize);
   }
+
+  if (m_nSize > kMaxDescribeEntries) {
+    snprintf(buf, bufSize, "... (%u entries truncated, total %u)\n", m_nSize - kMaxDescribeEntries, m_nSize);
+    sDescription += buf;
+  }
 }
 

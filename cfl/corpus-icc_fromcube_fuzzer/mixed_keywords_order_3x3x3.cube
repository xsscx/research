# Keywords in unusual ordering — domain before size, comments between keywords
DOMAIN_MIN -0.1 -0.1 -0.1
DOMAIN_MAX 1.1 1.1 1.1
# Film emulation LUT
TITLE "Mixed Order Keywords"
LUT_IN_VIDEO_RANGE
LUT_3D_SIZE 3

digraph iccApplyProfiles {
  rankdir=TB;
  node [shape=box, style=filled, fontname="Helvetica", fontsize=10];
  edge [fontname="Helvetica", fontsize=8];

  // Legend
  subgraph cluster_legend {
    label="Legend"; style=dashed; fontsize=9;
    leg_both [label="In Tool + Fuzzer", fillcolor="#90EE90"];
    leg_tool [label="Tool Only", fillcolor="#ADD8E6"];
    leg_cli  [label="CLI Only", fillcolor="#D3D3D3"];
    leg_fuzzer [label="Fuzzer Extra", fillcolor="#FFD700"];
  }

  // Entry points
  main [label="main()\niccApplyProfiles.cpp", fillcolor="#FF6B6B", shape=ellipse];
  fuzzer [label="LLVMFuzzerTestOneInput()\nicc_applyprofiles_fuzzer.cpp", fillcolor="#FF6B6B", shape=ellipse];

  subgraph cluster_config {
    label="Phase 1: Config Parsing"; style=rounded;
    n0 [label="CIccCfgDataApply::fromJson\nL158", fillcolor="#D3D3D3"];
    n1 [label="CIccCfgDataApply::fromLegacy\nL193", fillcolor="#D3D3D3"];
  }

  subgraph cluster_tiff_src {
    label="Phase 2: Source Image"; style=rounded;
    n2 [label="CTiffImg::Open\nL206", fillcolor="#ADD8E6"];
    n3 [label="CTiffImg::GetSamples\nL210", fillcolor="#ADD8E6"];
    n4 [label="CTiffImg::GetExtraSamples\nL211", fillcolor="#ADD8E6"];
    n5 [label="CTiffImg::GetPhoto\nL212", fillcolor="#ADD8E6"];
    n6 [label="CTiffImg::GetBitsPerSample\nL213", fillcolor="#ADD8E6"];
    n7 [label="CTiffImg::GetIccProfile\nL251", fillcolor="#ADD8E6"];
    n8 [label="CTiffImg::GetCompress\nL254", fillcolor="#ADD8E6"];
    n9 [label="CTiffImg::GetPlanar\nL255", fillcolor="#ADD8E6"];
  }

  subgraph cluster_cmm_build {
    label="Phase 3: CMM Construction"; style=rounded;
    n10 [label="CIccCmm::CIccCmm\nL262", fillcolor="#90EE90"];
    n11 [label="OpenIccProfile\nL293", fillcolor="#ADD8E6"];
    n12 [label="CIccCreateXformHintManager\nL284", fillcolor="#90EE90"];
    n13 [label="CIccCmmEnvVarHint\nL304", fillcolor="#ADD8E6"];
    n14 [label="CIccCmmPccEnvVarHint\nL308", fillcolor="#ADD8E6"];
    n15 [label="CIccCmm::AddXform(buffer)\nL314", fillcolor="#ADD8E6"];
    n16 [label="CIccCmm::AddXform(file)\nL334", fillcolor="#90EE90"];
  }

  subgraph cluster_cmm_exec {
    label="Phase 4: CMM Execution"; style=rounded;
    n17 [label="CIccCmm::Begin\nL350", fillcolor="#90EE90"];
    n18 [label="CIccCmm::GetSourceSpace\nL364", fillcolor="#90EE90"];
    n19 [label="icGetSpaceSamples(src)\nL365", fillcolor="#90EE90"];
    n20 [label="CIccCmm::GetDestSpace\nL385", fillcolor="#90EE90"];
    n21 [label="icGetSpaceSamples(dst)\nL387", fillcolor="#90EE90"];
    n22 [label="CIccCmm::GetLastParentSpace\nL389", fillcolor="#90EE90"];
    n23 [label="icGetSpaceSamples(parent)\nL390", fillcolor="#ADD8E6"];
    n24 [label="CIccCmm::Apply\nL546", fillcolor="#90EE90"];
  }

  subgraph cluster_tiff_dst {
    label="Phase 5: Dest Image"; style=rounded;
    n25 [label="CTiffImg::Create\nL430", fillcolor="#ADD8E6"];
    n26 [label="CIccFileIO::Open\nL440", fillcolor="#ADD8E6"];
    n27 [label="CIccFileIO::GetLength\nL443", fillcolor="#ADD8E6"];
    n28 [label="CIccFileIO::Read\nL444", fillcolor="#ADD8E6"];
    n29 [label="CTiffImg::SetIccProfile\nL446", fillcolor="#ADD8E6"];
  }

  subgraph cluster_pixel {
    label="Phase 6: Pixel Loop"; style=rounded;
    n30 [label="CTiffImg::ReadLine\nL475", fillcolor="#ADD8E6"];
    n31 [label="UnitClip\nL483", fillcolor="#ADD8E6"];
    n32 [label="CTiffImg::WriteLine\nL615", fillcolor="#ADD8E6"];
    n33 [label="CTiffImg::Close(src)\nL629", fillcolor="#ADD8E6"];
    n34 [label="CTiffImg::Close(dst)\nL634", fillcolor="#ADD8E6"];
  }

  subgraph cluster_fuzzer_extra {
    label="Phase 7: Fuzzer Extras"; style=rounded;
    n35 [label="CIccCmm::GetNumXforms", fillcolor="#FFD700"];
    n36 [label="CIccCmm::Valid", fillcolor="#FFD700"];
    n37 [label="CIccCmm::GetLastSpace", fillcolor="#FFD700"];
  }

  main -> n0 [style=dashed];
  main -> n1 [style=dashed];
  main -> n2 [style=dashed];
  main -> n3 [style=dashed];
  main -> n4 [style=dashed];
  main -> n5 [style=dashed];
  main -> n6 [style=dashed];
  main -> n7 [style=dashed];
  main -> n8 [style=dashed];
  main -> n9 [style=dashed];
  main -> n10 [style=bold];
  main -> n11 [style=dashed];
  main -> n12 [style=bold];
  main -> n13 [style=dashed];
  main -> n14 [style=dashed];
  main -> n15 [style=dashed];
  main -> n16 [style=bold];
  main -> n17 [style=bold];
  main -> n18 [style=bold];
  main -> n19 [style=bold];
  main -> n20 [style=bold];
  main -> n21 [style=bold];
  main -> n22 [style=bold];
  main -> n23 [style=dashed];
  main -> n24 [style=bold];
  main -> n25 [style=dashed];
  main -> n26 [style=dashed];
  main -> n27 [style=dashed];
  main -> n28 [style=dashed];
  main -> n29 [style=dashed];
  main -> n30 [style=dashed];
  main -> n31 [style=dashed];
  main -> n32 [style=dashed];
  main -> n33 [style=dashed];
  main -> n34 [style=dashed];
  fuzzer -> n35 [style=bold, color=orange];
  fuzzer -> n36 [style=bold, color=orange];
  fuzzer -> n37 [style=bold, color=orange];
  fuzzer -> n10 [style=dotted, color=green];
  fuzzer -> n12 [style=dotted, color=green];
  fuzzer -> n16 [style=dotted, color=green];
  fuzzer -> n17 [style=dotted, color=green];
  fuzzer -> n18 [style=dotted, color=green];
  fuzzer -> n19 [style=dotted, color=green];
  fuzzer -> n20 [style=dotted, color=green];
  fuzzer -> n21 [style=dotted, color=green];
  fuzzer -> n22 [style=dotted, color=green];
  fuzzer -> n24 [style=dotted, color=green];
}
